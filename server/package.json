{
  "name": "presight-server",
  "version": "1.0.0",
  "license": "MIT",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "seed": "tsx src/seed/seed.ts",
    "build": "tsc -p tsconfig.json && mkdir -p dist/db && cp src/db/schema.sql dist/db/",
    "start": "node dist/index.js",
    "test": "vitest run"
  },
  "dependencies": {
    "@faker-js/faker": "~9.6.0",
    "better-sqlite3": "~12.11.1",
    "express": "~5.1.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "~7.6.12",
    "@types/express": "~5.0.1",
    "@types/node": "~22.14.0",
    "@types/supertest": "~6.0.3",
    "supertest": "~7.1.0",
    "tsx": "~4.19.3",
    "typescript": "~5.8.3",
    "vitest": "~3.1.1"
  }
}
