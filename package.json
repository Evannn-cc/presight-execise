{
  "name": "presight-execise",
  "version": "1.0.0",
  "private": true,
  "repository": "",
  "author": "",
  "license": "MIT",
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "concurrently -n server,client -c blue,green \"npm run dev -w presight-server\" \"npm run dev -w presight-client\"",
    "seed": "npm run seed -w presight-server",
    "build": "npm run build -w presight-server && npm run build -w presight-client",
    "test": "npm test -w presight-server",
    "start": "npm run start -w presight-server",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "concurrently": "~9.1.2",
    "lerna": "~8.2.1",
    "prettier": "~3.5.3"
  }
}
